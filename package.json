{
  "name": "pulse-fx",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:web": "npm run dev -w apps/web",
    "dev:gateway": "npm run dev -w apps/gateway",
    "dev:api-public": "npm run dev -w apps/api-public",
    "dev:api-sync": "npm run dev -w apps/api-sync",
    "test": "npm run test --workspaces --if-present",
    "pretest": "npm run generate -w packages/db && npm run build -w packages/db && npm run build -w packages/core",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "prisma:generate": "npm run generate -w packages/db",
    "prisma:migrate": "npm run migrate:dev -w packages/db"
  },
  "devDependencies": {
    "@eslint/js": "^9.9.0",
    "eslint": "^9.9.0",
    "eslint-plugin-react": "^7.35.0",
    "eslint-plugin-react-hooks": "^4.6.2",
    "globals": "^15.9.0",
    "typescript": "^5.5.3",
    "typescript-eslint": "^8.2.0"
  }
}
