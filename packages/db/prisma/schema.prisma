generator client {
  provider      = "prisma-client-js"
  // "native" cobre o ambiente de dev local (macOS/Linux glibc); o segundo
  // target é o engine correto para as imagens node:*-alpine (musl + OpenSSL 3),
  // usadas em todos os Dockerfiles deste monorepo.
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum SeriesSource {
  BCB
  FRED
}

enum SeriesType {
  DAILY   // ex.: câmbio (PTAX) -> variação comparada em dias úteis
  MONTHLY // ex.: indicadores macro -> variação comparada em meses
}

/// Catálogo de indicadores expostos pelo Pulse FX.
/// O "code" é o identificador estável usado pelo frontend e pelas rotas.
model Indicator {
  code           String       @id
  name           String
  description    String
  source         SeriesSource
  sourceSeriesId String       // ex.: código SGS/PTAX no BCB, ou series_id no FRED
  seriesType     SeriesType
  unit           String       // ex.: "BRL", "%", "index"
  createdAt      DateTime     @default(now())

  observations Observation[]
  favorite     Favorite?
  syncState    SyncState?

  @@map("indicators")
}

/// Uma observação (ponto) da série temporal de um indicador.
model Observation {
  id            Int       @id @default(autoincrement())
  indicatorCode String
  indicator     Indicator @relation(fields: [indicatorCode], references: [code])
  referenceDate DateTime  @db.Date
  value         Decimal   @db.Decimal(18, 6)
  createdAt     DateTime  @default(now())

  @@unique([indicatorCode, referenceDate], name: "indicatorCode_referenceDate")
  @@index([indicatorCode, referenceDate])
  @@map("observations")
}

/// "Meus indicadores": favoritos persistidos no backend.
/// MVP de usuário único (sem autenticação multiusuário)
model Favorite {
  indicatorCode String    @id
  indicator     Indicator @relation(fields: [indicatorCode], references: [code])
  createdAt     DateTime  @default(now())

  @@map("favorites")
}

/// Controle de TTL / última sincronização por indicador, usado pelo api-sync
/// para evitar chamadas redundantes às APIs externas.
model SyncState {
  indicatorCode String    @id
  indicator     Indicator @relation(fields: [indicatorCode], references: [code])
  lastSyncedAt  DateTime?
  lastStatus    String? // "success" | "error"
  lastError     String?

  @@map("sync_state")
}
