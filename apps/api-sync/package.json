{
  "name": "api-sync",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "pretest": "cd ../../packages/db && npm run generate && npm run build && cd ../core && npm run build",
    "test": "vitest run",
    "test:watch": "npm run pretest && vitest"
  },
  "dependencies": {
    "@pulse-fx/core": "*",
    "@pulse-fx/db": "*",
    "amqplib": "^0.10.4",
    "express": "^4.19.2",
    "node-cron": "^3.0.3"
  },
  "devDependencies": {
    "@types/amqplib": "^0.10.5",
    "@types/express": "^4.17.21",
    "@types/node": "^20.14.10",
    "@types/node-cron": "^3.0.11",
    "@types/supertest": "^6.0.2",
    "supertest": "^7.0.0",
    "tsx": "^4.16.2",
    "typescript": "^5.5.3",
    "vitest": "^2.0.3"
  }
}
