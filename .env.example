# Postgres
POSTGRES_USER=pulsefx
POSTGRES_PASSWORD=pulsefx
POSTGRES_DB=pulsefx

# RabbitMQ
RABBITMQ_USER=pulsefx
RABBITMQ_PASS=pulsefx
RABBITMQ_URL=amqp://pulsefx:pulsefx@rabbitmq:5672

# Fontes externas
# Para gerar uma FRED_API_KEY, use o link https://fredaccount.stlouisfed.org/apikeys
FRED_API_KEY=SUA_CHAVE_FRED_AQUI

# Segurança
# Header "X-Admin-Key" exigido nas rotas administrativas do api-sync (POST /admin/sync)
ADMIN_API_KEY=SUA_CHAVE_AQUI

# TTL em minutos: intervalo mínimo entre sincronizações automáticas por indicador
SYNC_TTL_MINUTES=60

# Portas
API_PUBLIC_PORT=4001
API_SYNC_PORT=4002
GATEWAY_PORT=4000

# URL usada no Frontend
VITE_API_URL=http://localhost:4000
